# Copy this file to .env to run this kuberpult instance alongside another
# on the default ports (e.g. kuberpult_tags/ + kuberpult/ simultaneously).
#
# Usage:
#   cp .env.example .env   # in the second checkout
#   # then edit .env to make all ports and COMPOSE_PROJECT_NAME unique
#   make kuberpult-freshdb  # now uses offset ports and a separate project namespace
#
# The first checkout needs no .env — it keeps all defaults.

COMPOSE_PROJECT_NAME=kuberpult2

KUBERPULT_PORT_POSTGRES=4000
KUBERPULT_PORT_CD_HTTP=4001
KUBERPULT_PORT_CD_GRPC=4002
KUBERPULT_PORT_MANIFEST_HTTP=4003
KUBERPULT_PORT_MANIFEST_GRPC=4004
KUBERPULT_PORT_FRONTEND_HTTP=4005
KUBERPULT_PORT_FRONTEND_GRPC=4006
KUBERPULT_PORT_UI=4007
